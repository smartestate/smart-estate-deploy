# Core database settings
DB_USER=smartestate
DB_PASSWORD=
DB_HOST=postgres
DB_PORT=5432
DB_NAME=smartestate

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Routing / AI integrations (optional)
OPENAI_API_KEY=
ORS_API_KEY=
OPENROUTESERVICE_API_KEY=

# CORS and runtime
CORS_ORIGINS=https://app.smartestate.me,https://api.smartestate.me
ENVIRONMENT=production
UPLOAD_DIR=/app/uploads
SENTRY_DSN=

# Frontend / domain wiring
VITE_API_URL=https://api.smartestate.me/api
API_DOMAIN=api.smartestate.me
APP_DOMAIN=app.smartestate.me
CERTBOT_EMAIL=

# Optional git source defaults for setup.sh (not recommended for secrets)
# WARNING: Avoid storing GITHUB_PAT in .env for production; prefer entering PAT at runtime.
GITHUB_USERNAME=
GITHUB_PAT=
BACKEND_REPO=https://github.com/YOUR_ORG/smart-estate-backend.git
DASHBOARD_REPO=https://github.com/YOUR_ORG/smart-estate-dashboard.git